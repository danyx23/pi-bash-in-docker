{
  "name": "pi-bash-in-docker",
  "version": "0.1.0",
  "description": "Pi extension that keeps Pi on the host while running bash commands inside a Docker container",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "docker",
    "container",
    "bash"
  ],
  "pi": {
    "extensions": [
      "./extensions/pi-bash-in-docker"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@types/node": "^24.3.0",
    "typebox": "^1.1.24",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "MIT"
}
