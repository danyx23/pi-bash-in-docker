{
  "name": "pi-bash-in-docker",
  "version": "0.1.0",
  "description": "Pi extension that keeps Pi on the host while running bash commands inside a Docker container",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "docker",
    "container",
    "bash"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@types/node": "^22.15.0",
    "typebox": "^1.1.24",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
